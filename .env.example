# SSH tunnel (required if Workbench uses "Standard TCP/IP over SSH")
SSH_HOST=34.194.120.173
SSH_PORT=22
SSH_USER=pranish
SSH_KEY_FILE=/Users/uba/Downloads/pranish34.1

# MySQL target as seen FROM the SSH bastion (not from your laptop directly)
DB_HOST=ldr.monotype-prod-r53.com
DB_PORT=3306
DB_USER=readonly
DB_PASSWORD='your-password-here'
DB_NAME=myfonts

# Required if Workbench uses SSL (common with AWS RDS)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Date range for order lookup (inclusive)
ORDER_DATE_FROM=2013-01-01 00:00:00
ORDER_DATE_TO=2013-01-31 23:59:59
# 0 = fetch all orders in the date range
ORDER_LIMIT=0

# Shopify Admin API
SHOPIFY_SHOP=preprod-myfonts.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01

# Shopify order name format: DB OrderID 25170 -> Shopify name "#25170"
SHOPIFY_ORDER_NAME_PREFIX='#'

# Batch lookup: 50 IDs per API call, 4 parallel batches
SHOPIFY_BATCH_SIZE=50
SHOPIFY_CONCURRENCY=4
